# Override training/eval hyper-parameters WITHOUT editing docker-compose.yml.
#
#   cp .env.example .env   &&   edit .env      (docker compose auto-loads ./.env)
# or export any of these in your shell, e.g.:  MAX_STEPS=2 docker compose run --rm train
#
# Empty values fall through to each script's own argparse default (the entrypoint
# only appends a CLI flag when the variable is non-empty). Defaults shown are the
# docker-compose.yml fallbacks.

# === Shared / train (src/train.py) ===
MODEL_ID=Qwen/Qwen3-1.7B   # base model id: HF hub name or a local/mounted path
EPOCHS=                    # number of training epochs (empty -> train.py default)
MAX_STEPS=                 # hard cap on training steps; set e.g. 2 for a quick smoke run (empty -> default -1 = use epochs)
PER_DEVICE_BATCH=          # per-device train batch size (empty -> train.py default)
MAX_LEN=                   # max sequence length in tokens (empty -> train.py default)

# === prepare (data/prepare_data.py) ===
INPUT_FILE=/data           # input file or directory inside the container (./data is mounted to /data:ro)
PREPARE_FORCE_FALLBACK=    # set to 1 for offline prep: lightweight tokenizer, no model download (empty = normal)

# === evaluate (src/evaluate.py) ===
EVAL_BATCH_SIZE=           # eval batch size (empty -> evaluate.py default 8)
EVAL_MAX_NEW_TOKENS=       # generation length during eval (empty -> evaluate.py default 16)
EVAL_SYNTHETIC=            # set to 1 for offline synthetic eval, no trained model needed (empty = real model eval)
